# Application Configuration
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://syspro_user:syspro_password@localhost:5432/syspro_erp_dev
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=syspro_user
DB_PASSWORD=syspro_password
DB_NAME=syspro_erp_dev
DB_MAX_CONNECTIONS=100
DB_CONNECTION_TIMEOUT=60000
DB_IDLE_TIMEOUT=30000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DEFAULT_TTL=300
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=1800

# JWT Configuration
JWT_SECRET=syspro-jwt-secret-change-in-production-please
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=syspro-refresh-secret-change-in-production-please
JWT_REFRESH_EXPIRES_IN=7d
JWT_PASSWORD_RESET_SECRET=syspro-password-reset-secret-change-in-production
JWT_PASSWORD_RESET_EXPIRES_IN=1h
JWT_EMAIL_VERIFICATION_SECRET=syspro-email-verification-secret-change-in-production
JWT_EMAIL_VERIFICATION_EXPIRES_IN=24h

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Features
ENABLE_SWAGGER=true
ENABLE_METRICS=false
MAINTENANCE_MODE=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Configuration (for future implementation)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@syspro.com

# Cloud Storage (for future implementation)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=syspro-uploads