FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY turbo.json ./
COPY apps/web/package*.json ./apps/web/
COPY libs/shared/package*.json ./libs/shared/

# Install dependencies
RUN npm ci

# Copy source code
COPY apps/web ./apps/web
COPY libs ./libs

# Build shared libraries
RUN npm run build --workspace=@syspro/shared

WORKDIR /app/apps/web

EXPOSE 3000

CMD ["npm", "run", "dev"]