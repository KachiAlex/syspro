{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://syspro-erp-api.vercel.app/api/:path*"
    }
  ]
}