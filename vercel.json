{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/hello.ts",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/pure.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/hello",
      "dest": "/backend/api/hello.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/pure.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "backend/api/hello.ts": {
      "maxDuration": 5
    },
    "backend/api/pure.ts": {
      "maxDuration": 10
    }
  }
}
