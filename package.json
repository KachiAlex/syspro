{
  "name": "syspro-erp-monorepo",
  "version": "1.0.0",
  "description": "Production-grade multi-tenant ERP system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:api": "npm run build --workspace=@syspro/shared && npm run build --workspace=@syspro/database && npm run build --workspace=@syspro/api",
    "build:web": "cd apps/web && npm install && npm run build",
    "build:vercel": "npm run build:api",
    "dev": "turbo run dev --parallel",
    "dev:api": "npm run dev --workspace=@syspro/api",
    "dev:web": "npm run dev --workspace=@syspro/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:dev": "docker-compose -f docker/docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker/docker-compose.prod.yml up",
    "db:migrate": "cd apps/api && npm run migration:run",
    "db:seed": "cd apps/api && npm run seed:run",
    "postinstall": "node -e \"if (!process.env.CI && !process.env.VERCEL && !process.env.GITHUB_ACTIONS) { try { require('child_process').execSync('husky install', { stdio: 'inherit' }); } catch (e) { console.log('Husky setup skipped'); } }\"",
    "vercel-build": "npm run build:web",
    "deploy:setup": "node scripts/deploy-setup.js",
    "deploy:check": "curl $VERCEL_URL/api/v1/health || echo 'API not responding'",
    "pre-deploy": "node scripts/pre-deploy-check.js",
    "deploy:validate": "node scripts/pre-deployment-checker.js",
    "deploy:check-final": "node scripts/final-validation.js",
    "validate:packages": "node scripts/validate-packages.js",
    "validate:build": "node scripts/build-check.js",
    "test:deployment": "node scripts/deployment-test.js",
    "check:deployment": "node scripts/check-deployment.js",
    "build:validate": "npx ts-node scripts/build-validator.ts",
    "build:validate:routes": "npx ts-node scripts/build-validator.ts --test-routes",
    "deploy:strategy1": "npx ts-node scripts/vercel-config-manager.ts dashboard",
    "deploy:strategy2": "npx ts-node scripts/vercel-config-manager.ts vercel-json",
    "deploy:strategy3": "npx ts-node scripts/vercel-config-manager.ts cli",
    "deploy:strategy4": "npx ts-node scripts/vercel-config-manager.ts separate",
    "test:routes": "npx ts-node scripts/route-testing-engine.ts",
    "test:vercel": "npx ts-node scripts/vercel-config-manager.ts test",
    "status:check": "npx ts-node scripts/deployment-status-check.ts"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1",
    "axios": "^1.6.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "fast-check": "^3.15.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "turbo": "^1.13.4",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
