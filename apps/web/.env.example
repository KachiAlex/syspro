# Syspro ERP Frontend - Environment Variables
# Copy this file to .env.local and update the values

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Backend API URL - Point to your NestJS backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Node Environment (automatically set by Next.js)
NODE_ENV=development

# ===========================================
# INSTRUCTIONS
# ===========================================

# 1. Copy this file: cp .env.example .env.local
# 2. Update NEXT_PUBLIC_API_BASE_URL to match your backend URL
# 3. For production, use your deployed backend URL
# 4. Restart your development server after making changes

# ===========================================
# EXAMPLES FOR DIFFERENT ENVIRONMENTS
# ===========================================

# Local Development:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Production (Vercel):
# NEXT_PUBLIC_API_BASE_URL=https://your-api.vercel.app

# Docker Development:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001