{
  "version": 2,
  "name": "syspro-erp-api",
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ],
  "functions": {
    "dist/main.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  }
}