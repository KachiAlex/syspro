{
  "version": 2,
  "buildCommand": "npm run build:api",
  "outputDirectory": "apps/api/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "apps/api/dist/apps/api/src/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "methods": ["OPTIONS"],
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
