# Syspro ERP - Production Environment Variables
# Copy these to your Vercel project settings

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# JWT Configuration (GENERATE STRONG SECRETS!)
JWT_SECRET=your-super-secure-jwt-secret-256-bits-change-this
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-256-bits-change-this
JWT_PASSWORD_RESET_SECRET=your-password-reset-secret-256-bits-change-this
JWT_EMAIL_VERIFICATION_SECRET=your-email-verification-secret-256-bits-change-this

# Application Configuration
NODE_ENV=production
FRONTEND_URL=https://your-vercel-app.vercel.app
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://*.vercel.app

# ===========================================
# PERFORMANCE & SECURITY
# ===========================================

# API Configuration
API_PORT=3000

# Rate Limiting (more restrictive in production)
THROTTLE_TTL=60
THROTTLE_LIMIT=50

# Database Connection Pool (optimized for serverless)
DB_MAX_CONNECTIONS=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=10000

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Redis Cache (optional but recommended)
# REDIS_URL=redis://default:password@host:port

# Cache TTL Settings
REDIS_DEFAULT_TTL=180
REDIS_SESSION_TTL=3600
REDIS_CACHE_TTL=900

# Feature Flags
ENABLE_SWAGGER=false
ENABLE_METRICS=true
MAINTENANCE_MODE=false
PLATFORM_TENANT_CODE=PLATFORM

# ===========================================
# INSTRUCTIONS
# ===========================================

# 1. Replace all placeholder values with actual values
# 2. Generate strong JWT secrets using: openssl rand -base64 32
# 3. Get your Neon database connection string from Neon console
# 4. Set your actual Vercel app URL
# 5. Add these to Vercel project settings → Environment Variables