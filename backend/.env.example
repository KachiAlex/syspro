# Application Environment
NODE_ENV=development
PORT=4000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=syspro
DATABASE_PASSWORD=syspro_password
DATABASE_NAME=syspro_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# Stripe Configuration (Billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Flutterwave Configuration (Billing)
FLW_SECRET_KEY=FLWSECK_your_flutterwave_secret_key
FLW_PUBLIC_KEY=FLWPUBK_your_flutterwave_public_key
FLW_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# Paystack Configuration (Billing)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Invoice Storage
INVOICE_STORAGE_PATH=./storage/invoices

# AWS S3 Configuration (Optional - for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@syspro.com

# RabbitMQ Configuration (Optional - for message queue)
RABBITMQ_URL=amqp://syspro:syspro_password@localhost:5672

# MinIO Configuration (Optional - for object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=syspro-storage

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
